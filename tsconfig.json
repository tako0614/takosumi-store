{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "types": ["bun", "node"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "spec",
    "src",
    "test",
    "web/src",
    "scripts/store-release*.ts",
    "scripts/store-staging*.ts",
    "scripts/self-host-deploy.ts"
  ]
}
