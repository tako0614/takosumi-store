{
  "name": "@takosjp/takosumi-store",
  "version": "0.1.13",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "description": "Takosumi Store — a self-hostable store for Takos Capsules with an open HTTP/JSON read API (TCS). Browse and install Capsules; publishers register listings.",
  "scripts": {
    "dev": "bunx wrangler dev --config wrangler.local.toml",
    "dev:web": "bunx vite --config web/vite.config.ts",
    "check": "tsc --noEmit",
    "test": "bun test test/ src/backend/ spec/",
    "build": "bunx vite build --config web/vite.config.ts",
    "deploy:self-host": "bun scripts/self-host-deploy.ts",
    "release:candidate": "bun scripts/store-release-candidate.ts",
    "release:staging-bootstrap": "bun scripts/store-staging-bootstrap-fixed-adapter.ts",
    "release:check": "bunx tsc --noEmit && bun test test/release-*.test.ts test/health-routes.test.ts",
    "lint": "bun run check",
    "fmt": "bunx prettier --write spec src web test scripts",
    "fmt:check": "bunx prettier --check spec src web test scripts",
    "db:generate": "bunx drizzle-kit generate",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@libsql/client": "^0.17.0",
    "@solidjs/router": "^0.15.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@cloudflare/workers-types": "^4.20260420.1",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "babel-preset-solid": "^1.9.12",
    "drizzle-kit": "^0.31.9",
    "prettier": "^3.4.0",
    "solid-refresh": "^0.6.3",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vite-plugin-solid": "^2.11.0",
    "vitefu": "^1.1.3",
    "wrangler": "^4.103.0"
  }
}
